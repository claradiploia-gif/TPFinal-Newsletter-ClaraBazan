    {
      "parameters": {
        "jsCode": "// 1. Obtenemos el primer elemento que viene de Gemini de forma segura\nconst inputItem = $input.first().json;\nlet htmlContent = \"\";\n\n// 2. Extraemos el texto intentando primero la ruta exacta de Gemini\nif (inputItem.content && inputItem.content.parts && inputItem.content.parts[0]) {\n  htmlContent = inputItem.content.parts[0].text;\n} else {\n  // Rutas alternativas por si n8n o el modelo cambian la estructura\n  htmlContent = inputItem.text || inputItem.output;\n}\n\n// Validación de seguridad por si el contenido está vacío\nif (!htmlContent) {\n  throw new Error(\"No se pudo extraer el texto HTML de Gemini. Verifica los datos que entrega el nodo anterior.\");\n}\n\n// 3. Generamos el nombre del archivo con la fecha actual\nconst currentDate = new Date().toISOString().split('T')[0];\nconst filename = `document_${currentDate}.html`;\n\n// 4. Convertimos el string a buffer binario para subirlo a Google Drive\nconst buffer = Buffer.from(htmlContent, 'utf8');\n\nreturn [{\n  json: {\n    fileName: filename,\n    mimeType: 'text/html'\n  },\n  binary: {\n    data: buffer\n  }\n}];"
      },
